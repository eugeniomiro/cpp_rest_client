{
    "tasks": [
        {
            "label": "CMake: configure (build/)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "dev-debug"
            ],
            "dependsOn": "VCPKG install",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: build (Debug, build/)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "dev-debug"
            ],
            "dependsOn": "CMake: configure (build/)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "VCPKG install",
            "type": "shell",
            "command": "${userHome}\\vcpkg\\vcpkg.exe",
            "args": [
                "install"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ],
    "version": "2.0.0"
}